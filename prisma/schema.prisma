generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URL")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR_MANAGER
  DEPT_MANAGER
  EMPLOYEE
  RECRUITER
  PAYROLL_MANAGER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  PROBATION
  NOTICE_PERIOD
  TERMINATED
  RESIGNED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  WORK_FROM_HOME
  HOLIDAY
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  FAILED
}

enum CandidateStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  SELECTED
  REJECTED
  OFFERED
  HIRED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum DocumentType {
  IDENTITY
  CONTRACT
  POLICY
  CERTIFICATE
  OTHER
}

enum NotificationType {
  LEAVE_REQUEST
  PAYROLL_UPDATE
  SYSTEM_ALERT
  ANNOUNCEMENT
  PERFORMANCE_REVIEW
  RECRUITMENT
}

enum AIActionType {
  CHAT_QUERY
  RESUME_PARSING
  CANDIDATE_MATCH
  DOCUMENT_GENERATION
  POLICY_SEARCH
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

// ------------------------------------------------------
// NEXTAUTH REQUIRED MODELS
// ------------------------------------------------------

model Account {
  id                String  @id @default(uuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(uuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------
// TENANT / COMPANY MANAGEMENT
// ------------------------------------------------------

model Company {
  id             String    @id @default(uuid()) @map("_id")
  name           String
  logoUrl        String?
  website        String?
  industry       String?
  employeeCount  Int       @default(0)
  timezone       String    @default("UTC")
  currency       String    @default("USD")
  subscription   Subscription?
  isActive       Boolean   @default(true)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  users          User[]
  departments    Department[]
  employees      Employee[]
  jobs           Job[]
  leaves         LeaveRequest[]
  leaveTypes     LeaveType[]
  payrolls       PayrollRun[]
  auditLogs      AuditLog[]
  policies       Policy[]
  notifications  Notification[]
}

enum PlanTier {
  STARTER
  GROWTH
  ENTERPRISE
}

model Subscription {
  id                     String    @id @default(uuid()) @map("_id")
  companyId              String    @unique
  stripeCustomerId       String?
  stripeSubscriptionId   String?   @unique
  planTier               PlanTier  @default(GROWTH) // Default to GROWTH for 14-day trial
  status                 String    @default("trialing")
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Department {
  id          String   @id @default(uuid()) @map("_id")
  companyId   String
  name        String
  description String?
  managerId   String? 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

// ------------------------------------------------------
// AUTHENTICATION & USERS
// ------------------------------------------------------

model User {
  id            String    @id @default(uuid()) @map("_id")
  email         String    @unique
  name          String?
  emailVerified DateTime?
  password      String?   // Added for Credentials auth
  image         String?
  companyId     String?
  role          UserRole  @default(EMPLOYEE)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  company       Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee      Employee?
  
  accounts      Account[]
  sessions      Session[]
  notifications Notification[]
  
  crops         Crop[]
  irrigation    IrrigationSystem?
  
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  @@index([companyId])
}

// ------------------------------------------------------
// EMPLOYEE MANAGEMENT
// ------------------------------------------------------

model Employee {
  id               String         @id @default(uuid()) @map("_id")
  companyId        String
  userId           String         @unique
  departmentId     String?
  
  employeeCode     String
  firstName        String
  lastName         String
  designation      String?
  joiningDate      DateTime
  status           EmployeeStatus @default(ACTIVE)
  
  workEmail        String
  personalEmail    String?
  phone            String?

  // Salary configuration — null means "not yet set / to be backfilled"
  baseSalary       Float?         // Monthly gross base salary (e.g. 50000.00)
  allowancePercent Float?         // Allowances as % of baseSalary (default: 20%)
  deductionPercent Float?         // Deductions as % of baseSalary (default: 12%)
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  department       Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  payslips         Payslip[]
  documents        Document[]
  goals            Goal[]

  @@unique([companyId, employeeCode])
  @@index([companyId, status])
  @@index([departmentId])
}

// ------------------------------------------------------
// ATTENDANCE MANAGEMENT
// ------------------------------------------------------

model Attendance {
  id            String           @id @default(uuid()) @map("_id")
  employeeId    String
  date          DateTime
  checkInTime   DateTime?
  checkOutTime  DateTime?
  status        AttendanceStatus
  totalHours    Float?
  ipAddress     String?
  notes         String?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId, status])
  @@index([date])
}

// ------------------------------------------------------
// LEAVE MANAGEMENT
// ------------------------------------------------------

model LeaveRequest {
  id            String      @id @default(uuid()) @map("_id")
  companyId     String
  employeeId    String
  leaveTypeId   String?
  leaveType     LeaveType?  @relation(fields: [leaveTypeId], references: [id], onDelete: SetNull)

  startDate     DateTime
  endDate       DateTime
  totalDays     Float
  reason        String
  status        LeaveStatus @default(PENDING)
  approvedById  String?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
}

// ------------------------------------------------------
// PAYROLL MANAGEMENT
// ------------------------------------------------------

model LeaveType {
  id                  String         @id @default(uuid()) @map("_id")
  companyId           String
  name                String         // e.g. "Casual Leave", "Sick Leave"
  annualQuota         Int
  carryForwardAllowed Boolean        @default(false)
  isPaid              Boolean        @default(true)

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leaveRequests       LeaveRequest[]

  @@index([companyId])
}


model PayrollRun {
  id            String        @id @default(uuid()) @map("_id")
  companyId     String
  month         Int
  year          Int
  status        PayrollStatus @default(DRAFT)
  totalAmount   Float
  processedById String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payslips      Payslip[]

  @@unique([companyId, month, year])
  @@index([companyId, status])
}

model Payslip {
  id            String      @id @default(uuid()) @map("_id")
  payrollRunId  String
  employeeId    String
  basicSalary   Float
  allowances    Float
  deductions    Float
  netSalary     Float
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  payrollRun    PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee      Employee    @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

// ------------------------------------------------------
// RECRUITMENT MANAGEMENT
// ------------------------------------------------------

model Job {
  id            String      @id @default(uuid()) @map("_id")
  companyId     String
  title         String
  department    String
  location      String
  type          String
  description   String
  requirements  String
  isActive      Boolean     @default(true)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidates    Candidate[]

  @@index([companyId, isActive])
}

model Candidate {
  id            String          @id @default(uuid()) @map("_id")
  jobId         String
  firstName     String
  lastName      String
  email         String
  phone         String?
  resumeUrl     String?
  status        CandidateStatus @default(APPLIED)
  aiMatchScore  Float?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  job           Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
}

// ------------------------------------------------------
// DOCUMENT MANAGEMENT
// ------------------------------------------------------

model Document {
  id            String       @id @default(uuid()) @map("_id")
  employeeId    String
  title         String
  type          DocumentType
  fileUrl       String
  isVerified    Boolean      @default(false)
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ------------------------------------------------------
// AUDIT LOGS
// ------------------------------------------------------

model AuditLog {
  id            String   @id @default(uuid()) @map("_id")
  companyId     String   @db.ObjectId
  userId        String?
  module        String
  action        String
  recordId      String
  oldData       Json?
  newData       Json?
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime @default(now())

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, module])
  @@index([companyId, createdAt])
}

// ------------------------------------------------------
// AI ASSISTANT
// ------------------------------------------------------

model AILog {
  id            String        @id @default(uuid()) @map("_id")
  companyId     String
  userId        String
  actionType    AIActionType
  prompt        String
  response      String
  tokensUsed    Int           @default(0)
  
  createdAt     DateTime      @default(now())

  @@index([companyId, actionType])
}

// ------------------------------------------------------
// PERFORMANCE MANAGEMENT
// ------------------------------------------------------

model Goal {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  employeeId    String      @db.ObjectId
  title         String
  description   String
  status        GoalStatus  @default(NOT_STARTED)
  progress      Int         @default(0) // 0-100
  dueDate       DateTime
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ------------------------------------------------------
// POLICY MANAGEMENT
// ------------------------------------------------------

model Policy {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  companyId     String      @db.ObjectId
  title         String
  description   String
  category      String      @default("General")
  fileUrl       String?
  effectiveDate DateTime
  isActive      Boolean     @default(true)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive])
}

model Notification {
  id          String   @id @default(uuid()) @map("_id")
  companyId   String
  userId      String
  title       String
  message     String
  type        String   // 'LEAVE', 'PAYROLL', 'SYSTEM', etc.
  isRead      Boolean  @default(false)
  link        String?
  
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([companyId])
}

// ------------------------------------------------------
// SMART FARMING INDIA MODELS
// ------------------------------------------------------

model Crop {
  id             String    @id @default(uuid()) @map("_id")
  userId         String
  name           String
  area           Float
  healthScore    Int
  stage          String
  harvestDays    Int
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MandiPrice {
  id             String    @id @default(uuid()) @map("_id")
  cropName       String
  market         String
  price          Float
  unit           String    @default("qtl")
  trendPercent   Float
  trendDirection String    @default("UP") // UP or DOWN
  isLive         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model IrrigationSystem {
  id             String    @id @default(uuid()) @map("_id")
  userId         String    @unique
  status         String    @default("Active")
  pumpName       String    @default("Pump #1")
  sector         String    @default("Sector A")
  waterUsage     Float     @default(0) // Liters
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// MARKETPLACE MODELS
// ------------------------------------------------------

model MarketplaceProduct {
  id          String   @id @default(uuid()) @map("_id")
  name        String
  seller      String
  location    String
  rating      Float
  price       Float
  priceUnit   String?
  type        String   // "buy" or "rental"
  image       String
  imageAlt    String
  category    String
  stock       String?
  badge       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  cartItems   CartItem[]
  wishlists   WishlistItem[]
}

model CartItem {
  id          String   @id @default(uuid()) @map("_id")
  userId      String
  productId   String
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model WishlistItem {
  id          String   @id @default(uuid()) @map("_id")
  userId      String
  productId   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

